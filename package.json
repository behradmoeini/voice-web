{
  "name": "praxify-voice-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.16.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "preview": "vite preview",
    "start:twilio": "tsx server/twilio-bridge.ts",
    "sync:env": "node scripts/sync-env-from-voice-agent.mjs",
    "dev:twilio": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch server/twilio-bridge.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:twilio\"",
    "railway:login": "railway login",
    "railway:link": "railway link",
    "railway:deploy": "railway up",
    "railway:logs": "railway logs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.50",
    "ai": "^6.0.146",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "sonner": "^2.0.7",
    "tsx": "^4.19.2",
    "twilio": "^5.3.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@railway/cli": "^4.36.1",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.12",
    "@vercel/node": "^5.6.22",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "localtunnel": "^2.0.2",
    "typescript": "~5.6.2",
    "vite": "^5.4.10"
  }
}

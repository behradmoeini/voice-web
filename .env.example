# Copy from voice-agent or run: npm run sync:env
# OPENAI_API_KEY=sk-...

# Realtime model for WebRTC voice sessions
# OPENAI_REALTIME_MODEL=gpt-realtime

# Realtime output voice (examples: marin, cedar, alloy, ash, ballad, coral, echo, sage, shimmer, verse)
# OPENAI_REALTIME_VOICE=marin

# ─── Twilio Bridge Server (server/twilio-bridge.ts) ───────────────────────────
# Twilio credentials — from https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number in E.164 format
# TWILIO_PHONE_NUMBER=+15550001234

# Optional: routed live transfer targets for callers who want a human handoff
# Administrative default: +16136215075
# Technical default: +13435752183
# TWILIO_ADMIN_TRANSFER_NUMBER=+16136215075
# TWILIO_TECHNICAL_TRANSFER_NUMBER=+13435752183

# Port the bridge server listens on (default: 5051)
# TWILIO_BRIDGE_PORT=5051

# Public HTTPS base URL for the bridge server.
# In dev: use ngrok — e.g. https://abc123.ngrok-free.app
# In prod: your Railway/Render deployment URL
# TWILIO_BRIDGE_PUBLIC_URL=https://abc123.ngrok-free.app
